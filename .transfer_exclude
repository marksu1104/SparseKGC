# Files/dirs to EXCLUDE when transferring to HPC
# Use with: rsync --exclude-from=.transfer_exclude

# DacKGR trained model checkpoints (will retrain on HPC)
baselines/DacKGR/model/

# DacKGR processed data (will regenerate via process_data stage)
baselines/DacKGR/data/

# Prob-CBR cached data (will regenerate)
baselines/Prob-CBR/prob-cbr-data/

# Outputs from local runs (fresh run on HPC)
outputs/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo

# HoGRN checkpoints
baselines/HoGRN/checkpoints/

# Traditional checkpoints
baselines/tranditional/checkpoints/
